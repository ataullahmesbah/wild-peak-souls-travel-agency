# ─────────────────────────────────────────────
# Wild Peak Souls — Environment Configuration
# ─────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_NAME="Wild Peak Souls"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Database (PostgreSQL via Neon)
DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech/db?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech/db?sslmode=require
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Authentication (NextAuth)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Payment — Stripe (Phase 2)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Payment — PayPal (Phase 2)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""

# Payment — SSLCommerz (Phase 2)
SSLCZ_STORE_ID=""
SSLCZ_STORE_PASSWD=""
SSLCZ_API_BASE_URL=""

# Email (SMTP)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""

# Cloud Storage / CDN
CDN_BASE_URL=""

# Analytics
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_ANALYTICS_DOMAIN=""
