# ─────────────────────────────────────────────────────────────────
# Wild Peak Souls — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit actual values to version control.
# ─────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Wild Peak Souls"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Database — Neon PostgreSQL ─────────────────────────────────────
# Use the pooled connection URL for runtime (pgbouncer compatible)
DATABASE_URL=
# Use the direct (non-pooled) URL for Prisma migrations
DIRECT_DATABASE_URL=

# ── Authentication — NextAuth ──────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── OAuth — Google ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cloudinary (Image Hosting & CDN) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ── Email — SMTP ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME="Wild Peak Souls"
SMTP_FROM_EMAIL=noreply@wildpeaksouls.com

# ── Payment — Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Payment — PayPal ───────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# ── Payment — SSLCommerz ───────────────────────────────────────────
SSL_COMMERZ_STORE_ID=
SSL_COMMERZ_STORE_PASSWORD=
SSL_COMMERZ_IS_LIVE=false

# ── Security ───────────────────────────────────────────────────────
# Rate limiting (requests per window per IP)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ── Analytics ──────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ANALYTICS_DOMAIN=

# ── CDN / Media ────────────────────────────────────────────────────
CDN_BASE_URL=
